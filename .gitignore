# Per-order prepared itemText files — operational content, not part of the script
backend/dristi-services/transformer/scripts/texts/*.html
backend/dristi-services/transformer/scripts/texts/*.htm
backend/dristi-services/transformer/scripts/texts/*.txt

# Python bytecode
backend/dristi-services/transformer/scripts/__pycache__/
