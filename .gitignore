# Local-only RequestInfo for the order update scripts (contains live auth token)
backend/dristi-services/transformer/scripts/request_info.json

# Per-order snapshots/diffs written by update_orders.py — contain live order data
backend/dristi-services/transformer/scripts/results/*.json
